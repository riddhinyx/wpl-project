RewriteEngine On

# Never serve environment files
<FilesMatch "^\.env">
  Require all denied
</FilesMatch>

# If the requested path is a real file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route all /api/* requests to the API front controller
RewriteRule ^api/?$ api/index.php [L,QSA]
RewriteRule ^api/(.*)$ api/index.php [L,QSA]
